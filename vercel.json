{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/*.js": {
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "routes": [
    { "src": "/api/x-cloak", "dest": "/api/x-cloak.js" },
    { "src": "/api/create-pix", "dest": "/api/create-pix.js" },
    { "src": "/api/check-status", "dest": "/api/check-status.js" },
    { "src": "/api/fb-capi", "dest": "/api/fb-capi.js" },
    { "src": "/api/webhook-blackcat", "dest": "/api/webhook-blackcat.js" },
    { "src": "^/($|index|index.html|index.php|index.js|middleware.js)", "dest": "/api/x-cloak" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
